{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/workday-payroll/refs/heads/main/json-structure/payroll-results-worker-result-structure.json",
  "name": "WorkerResult",
  "description": "WorkerResult schema from Workday Payroll Results API",
  "type": "object",
  "properties": {
    "worker": {
      "$ref": "#/$defs/WorkerRef"
    },
    "grossPay": {
      "type": "double",
      "description": "Worker gross pay for this run",
      "example": 1.0
    },
    "netPay": {
      "type": "double",
      "description": "Worker net pay for this run",
      "example": 1.0
    },
    "totalEarnings": {
      "type": "double",
      "description": "Total earnings",
      "example": 5240.0
    },
    "totalDeductions": {
      "type": "double",
      "description": "Total deductions",
      "example": 38210.8
    },
    "totalTaxes": {
      "type": "double",
      "description": "Total taxes withheld",
      "example": 29167.4
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code",
      "example": "USD"
    },
    "paymentMethod": {
      "type": "string",
      "enum": [
        "DirectDeposit",
        "Check",
        "Wire"
      ],
      "description": "Method of payment",
      "example": "DirectDeposit"
    }
  },
  "definitions": {
    "WorkerRef": {
      "name": "WorkerRef",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Worker identifier",
          "example": "w_100542"
        },
        "descriptor": {
          "type": "string",
          "description": "Worker display name",
          "example": "Weekly USD Pay Group"
        }
      }
    }
  }
}
