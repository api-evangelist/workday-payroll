      "@id": "workday:taxable_wages",
      "@type": "xsd:double"
    },
    "total": {
      "@id": "workday:total",
      "@type": "xsd:integer"
    },
    "totalEmployerTax": {
      "@id": "workday:total_employer_tax",
      "@type": "xsd:double"
    },
    "totalFederalWithholding": {
      "@id": "workday:total_federal_withholding",
