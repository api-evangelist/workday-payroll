    },
    "totalTaxWithheld": {
      "@id": "workday:total_tax_withheld",
      "@type": "xsd:double"
    },
    "totalTaxableWages": {
      "@id": "workday:total_taxable_wages",
      "@type": "xsd:double"
    },
